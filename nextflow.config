// Tiberius dataprep -- Nextflow configuration entry point.
//
// Auto-loaded by `nextflow run` when invoked from the repo root.
// Select an execution profile with `-profile <name>`:
//
//   -profile test                local, no container; for -stub-run and CI
//   -profile local_docker        local laptop with Docker
//   -profile local_singularity   local workstation with Singularity
//   -profile slurm_brain         BRAIN cluster (Univ. Greifswald) with Singularity
//   -profile slurm_generic       any Slurm cluster with Singularity (no queue/clusterOptions assumed)
//
// To target a different cluster, copy conf/slurm_generic.config to
// conf/slurm_<yourname>.config, adjust the executor/queue/cpus/memory/time
// to your site, and add a matching entry to the `profiles` block below.

profiles {
    test {
        includeConfig 'conf/test.config'
    }
    local_docker {
        includeConfig 'conf/local_docker.config'
    }
    local_singularity {
        includeConfig 'conf/local_singularity.config'
    }
    slurm_brain {
        includeConfig 'conf/slurm_brain.config'
    }
    slurm_generic {
        includeConfig 'conf/slurm_generic.config'
    }
}
