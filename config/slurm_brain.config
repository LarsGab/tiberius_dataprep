// BRAIN cluster (Univ. Greifswald) with Singularity.
//
// If publishDir copies of large .tfrecords files hang on the shared FS, throttle
// concurrent submissions by adding (outside of `process`):
//   executor.queueSize = 8
// or switch to hard links by setting `publishDir mode: 'link'` in genome2tfrecords.nf.
includeConfig 'base.config'

docker.enabled           = false
singularity.enabled      = true
singularity.autoMounts   = true
singularity.envWhitelist = 'CUDA_VISIBLE_DEVICES'

process {
    executor       = 'slurm'
    queue          = 'snowball,pinky'
    cpus           = 40
    memory         = '70 GB'
    time           = '12h'
    clusterOptions = '--get-user-env'

    withLabel: 'gpu' {
        queue            = 'vision,vision-fast'
        clusterOptions   = '--gpus=1 --get-user-env'
        containerOptions = '--nv'
    }
}
