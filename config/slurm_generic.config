// Generic Slurm cluster with Singularity. No queue or clusterOptions
// assumed -- copy this file and adjust for your site.
includeConfig 'base.config'

docker.enabled           = false
singularity.enabled      = true
singularity.autoMounts   = true
singularity.envWhitelist = 'CUDA_VISIBLE_DEVICES'

process {
    executor = 'slurm'
    cpus     = 8
    memory   = '16 GB'
    time     = '2h'

    withLabel: 'gpu' {
        clusterOptions   = '--gpus=1'
        containerOptions = '--nv'
    }
}
